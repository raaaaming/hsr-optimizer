{
  "name": "hsr-optimizer",
  "version": "0.1.0",
  "description": "Honkai: Star Rail Build Optimizer & Battle Simulator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "wrangler deploy --dry-run",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create hsr-optimizer",
    "db:migrate": "wrangler d1 migrations apply hsr-optimizer --local",
    "db:migrate:remote": "wrangler d1 migrations apply hsr-optimizer --remote",
    "db:console": "wrangler d1 execute hsr-optimizer --local --command"
  },
  "keywords": [
    "hsr",
    "honkai",
    "starrail",
    "optimizer",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.27.0"
  }
}